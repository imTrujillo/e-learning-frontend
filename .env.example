# URL base del API de estudiantes (learning-students), sin barra final.
# learning-engine suele ir en 8081; el SPA habla con learning-students (8083 en IDE, 8081 si usas docker-compose allí).
VITE_API_URL=http://localhost:8083

# learning-engine (catálogo + inscripciones). Incluye `/api` sin barra final.
VITE_ENGINE_URL=http://localhost:8081/api
