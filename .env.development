# En desarrollo, el API se llama por proxy (vite.config.ts → learning-students por defecto :8083).
# learning-engine (catálogo / inscripciones): proxy `/engine-api` → :8081 por defecto.
# (PowerShell) $env:VITE_ENGINE_PROXY_TARGET="http://localhost:9090"; npm run dev
# VITE_ENGINE_PROXY_TARGET=http://localhost:8081
# No hace falta VITE_API_URL aquí salvo que hagas build/preview y quieras forzar URL.
# VITE_API_URL=http://localhost:8083

# Si el backend corre en otro host:puerto, úsalo para el proxy (p. ej. Docker del servicio en 8081):
# (PowerShell) $env:VITE_PROXY_TARGET="http://localhost:8081"; npm run dev
# VITE_PROXY_TARGET=http://localhost:8081
